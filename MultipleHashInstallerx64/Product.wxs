		<!-- Detect folder for SQL 2017 x64 installation -->

		<Property Id="SSIS64_2017_PATH_1" Secure="yes">
			<RegistrySearch Type="directory" Id="SSIS64_2017_PATH_p1" Root="HKLM" Key="SOFTWARE\Microsoft\Microsoft SQL Server\140\SSIS\Setup\DTSPath" Win64="yes"/>
