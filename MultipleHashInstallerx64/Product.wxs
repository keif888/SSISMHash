		<!-- Display a Warning dialog box IF SSIS isn't detected.  And don't forget to update the or statement below to include newer versions of SQL Server SSIS when added above. -->
		<UI>
			<InstallUISequence>
				<Show Dialog="SSISWarning" Before="ResumeDlg">NOT Installed AND NOT (SSIS32_2025 OR SSIS64_2025 OR SSIS32_2022 OR SSIS64_2022 OR SSIS32_2019 OR SSIS64_2019 OR SSIS32_2017 OR SSIS64_2017)</Show>
			</InstallUISequence>
			<Dialog Id="SSISWarning" Width="200" Height="100">
