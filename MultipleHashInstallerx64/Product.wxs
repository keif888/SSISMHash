<?xml version="1.0" encoding="UTF-8"?>
<Wix xmlns="http://schemas.microsoft.com/wix/2006/wi">
	<?define ProductVersion = "1.7.7.0"?>
	<?define UpgradeCode = "8E49EA91-5400-4782-B9C2-DBA091F563D4"?>
	<?define Manufacturer = "Keith Martin"?>
	<?define PackageCode = "*"?>

	<Product Id="*"
			 Name="Multiple Hash x64"
			 Language="1033"
			 Version="$(var.ProductVersion)"
			 Manufacturer="$(var.Manufacturer)"
			 UpgradeCode="$(var.UpgradeCode)">

		<Package Id="$(var.PackageCode)"
				 Description="Multiple Hash SSIS Transformation Component"
				 Comments="Installs version $(var.ProductVersion) of the dll's required for this component to work."
				 InstallerVersion="300"
				 Manufacturer="$(var.Manufacturer)"
				 Compressed="yes"
				 InstallScope="perMachine"
				 Platform="x64"/>

		<Property Id="ARPHELPLINK" Value="https://github.com/keif888/SSISMHash/" />

		<Media Id="1" Cabinet="HultipleHash.cab" EmbedCab="yes" />

		<MajorUpgrade
		  Schedule="afterInstallInitialize"
		  DowngradeErrorMessage="A later version of [ProductName] is already installed. Setup will now exit."/>

		<UIRef Id="WixUI_Mondo"/>
		<WixVariable Id="WixUILicenseRtf" Value="$(var.MultipleHash2025.ProjectDir)\License.rtf" />

		<!-- Override the Wix default actions.xml values as there is not enough space between AppSearch and LaunchConditions -->
		<InstallExecuteSequence>
			<AppSearch Sequence="50"></AppSearch>
			<LaunchConditions Sequence="200"></LaunchConditions> <!-- Original Value = 100, next sequence is 500 -->
		</InstallExecuteSequence>

		<InstallUISequence>
			<AppSearch Sequence="50"></AppSearch>
			<LaunchConditions Sequence="200"></LaunchConditions> <!-- Original Value = 100, next sequence is 500 -->
		</InstallUISequence>
		
		<!-- 
          The following works by creating 2 properties which may contain directory paths (where found in the reigstry).
          These properties are looked at progressively setting the SSIS____PATH, until one sets the path.
          Once the path is set, all subsequent ones are excluded by the condition.
          If neither of the registry keys has a value, then a default normally valid path is used so a custom install will have the correct(ish) path's, when forcing installation where SSIS isn't detected.
          
          This prevents the filesystem detection overriding the registry locations for where SQL Server SSIS is installed.
    -->
		<!-- Detect folder for SQL 2025 x64 installation -->

		<Property Id="SSIS64_2025_PATH_1" Secure="yes">
			<RegistrySearch Type="directory" Id="SSIS64_2025_PATH_p1" Root="HKLM" Key="SOFTWARE\Microsoft\Microsoft SQL Server\170\SSIS\Setup\DTSPath" Win64="yes"/>
		</Property>
		<Property Id="SSIS64_2025_PATH_2" Secure="yes">
			<RegistrySearch Type="directory" Id="SSIS64_2025_PATH_p2" Root="HKLM" Key="SOFTWARE\Microsoft\Microsoft SQL Server\170\DTS\Setup" Name="SQLPath" Win64="yes"/>
		</Property>

		<Property Id="SSIS64_2025_PATH" Secure="yes" />
		<SetProperty Action="SSIS64_2025_PATH_a" Id="SSIS64_2025_PATH" Sequence="both" After="AppSearch" Value=""/>
		<SetProperty Action="SSIS64_2025_PATH_a1" Id="SSIS64_2025_PATH" Sequence="both" After="AppSearch" Value="[SSIS64_2025_PATH_1]">SSIS64_2025_PATH=""</SetProperty>
		<SetProperty Action="SSIS64_2025_PATH_a2" Id="SSIS64_2025_PATH" Sequence="both" After="AppSearch" Value="[SSIS64_2025_PATH_2]">SSIS64_2025_PATH=""</SetProperty>
		<SetProperty Action="SSIS64_2025_PATH_a3" Id="SSIS64_2025_PATH" Sequence="both" After="AppSearch" Value="[ProgramFiles64Folder]\Microsoft SQL Server\170\DTS">SSIS64_2025_PATH=""</SetProperty>

		<!-- Detect folder for SQL 2025 x86 installation -->

		<Property Id="SSIS32_2025_PATH_1" Secure="yes">
			<RegistrySearch Type="directory" Id="SSIS32_2025_PATH_p1" Root="HKLM" Key="SOFTWARE\Microsoft\Microsoft SQL Server\170\SSIS\Setup\DTSPath" Win64="no"/>
		</Property>
		<Property Id="SSIS32_2025_PATH_2" Secure="yes">
			<RegistrySearch Type="directory" Id="SSIS32_2025_PATH_p2" Root="HKLM" Key="SOFTWARE\Microsoft\Microsoft SQL Server\170\DTS\Setup" Name="SQLPath" Win64="no"/>
		</Property>
		<Property Id="SSIS32_2025_PATH" Secure="yes" />
		<SetProperty Action="SSIS32_2025_PATH_a" Id="SSIS32_2025_PATH" Sequence="both" After="AppSearch" Value=""/>
		<SetProperty Action="SSIS32_2025_PATH_a1" Id="SSIS32_2025_PATH" Sequence="both" After="AppSearch" Value="[SSIS32_2025_PATH_1]">SSIS32_2025_PATH=""</SetProperty>
		<SetProperty Action="SSIS32_2025_PATH_a2" Id="SSIS32_2025_PATH" Sequence="both" After="AppSearch" Value="[SSIS32_2025_PATH_2]">SSIS32_2025_PATH=""</SetProperty>
		<SetProperty Action="SSIS32_2025_PATH_a3" Id="SSIS32_2025_PATH" Sequence="both" After="AppSearch" Value="[ProgramFilesFolder]\Microsoft SQL Server\170\DTS">SSIS32_2025_PATH=""</SetProperty>

		<!-- Detect folder for SQL 2022 x64 installation -->

		<Property Id="SSIS64_2022_PATH_1" Secure="yes">
			<RegistrySearch Type="directory" Id="SSIS64_2022_PATH_p1" Root="HKLM" Key="SOFTWARE\Microsoft\Microsoft SQL Server\160\SSIS\Setup\DTSPath" Win64="yes"/>
		</Property>
