		<Condition Message="You need to be an administrator to install this product.">
			Privileged
		</Condition>

		<Directory Id="TARGETDIR" Name="SourceDir">

			<!-- The following setup the Global Assembley Cache file drop components. -->

			<Component Id="SQL2025GAC" Guid="48CE3186-F22C-4B3F-B2EC-354E7C0F2025">
