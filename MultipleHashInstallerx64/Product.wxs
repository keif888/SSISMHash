		<Property Id="SSIS64_2022_PATH" Secure="yes" />
		<SetProperty Action="SSIS64_2022_PATH_a" Id="SSIS64_2022_PATH" Sequence="both" After="AppSearch" Value=""/>
		<SetProperty Action="SSIS64_2022_PATH_a1" Id="SSIS64_2022_PATH" Sequence="both" After="AppSearch" Value="[SSIS64_2022_PATH_1]">SSIS64_2022_PATH=""</SetProperty>
		<SetProperty Action="SSIS64_2022_PATH_a2" Id="SSIS64_2022_PATH" Sequence="both" After="AppSearch" Value="[SSIS64_2022_PATH_2]">SSIS64_2022_PATH=""</SetProperty>
		<SetProperty Action="SSIS64_2022_PATH_a3" Id="SSIS64_2022_PATH" Sequence="both" After="AppSearch" Value="[ProgramFiles64Folder]\Microsoft SQL Server\160\DTS">SSIS64_2022_PATH=""</SetProperty>
		
		<!-- Detect folder for SQL 2022 x86 installation -->

		<Property Id="SSIS32_2022_PATH_1" Secure="yes">
			<RegistrySearch Type="directory" Id="SSIS32_2022_PATH_p1" Root="HKLM" Key="SOFTWARE\Microsoft\Microsoft SQL Server\160\SSIS\Setup\DTSPath" Win64="no"/>
		</Property>
		<Property Id="SSIS32_2022_PATH_2" Secure="yes">
