		</Property>

		<Property Id="SSIS64_2017_PATH" Secure="yes" />
		<SetProperty Action="SSIS64_2017_PATH_a" Id="SSIS64_2017_PATH" Sequence="both" After="AppSearch" Value=""/>
		<SetProperty Action="SSIS64_2017_PATH_a1" Id="SSIS64_2017_PATH" Sequence="both" After="AppSearch" Value="[SSIS64_2017_PATH_1]">SSIS64_2017_PATH=""</SetProperty>
		<SetProperty Action="SSIS64_2017_PATH_a2" Id="SSIS64_2017_PATH" Sequence="both" After="AppSearch" Value="[SSIS64_2017_PATH_2]">SSIS64_2017_PATH=""</SetProperty>
		<SetProperty Action="SSIS64_2017_PATH_a3" Id="SSIS64_2017_PATH" Sequence="both" After="AppSearch" Value="[ProgramFiles64Folder]\Microsoft SQL Server\140\DTS">SSIS64_2017_PATH=""</SetProperty>

		<!-- Detect folder for SQL 2017 x86 installation -->

		<Property Id="SSIS32_2017_PATH_1" Secure="yes">
			<RegistrySearch Type="directory" Id="SSIS32_2017_PATH_p1" Root="HKLM" Key="SOFTWARE\Microsoft\Microsoft SQL Server\140\SSIS\Setup\DTSPath" Win64="no"/>
		</Property>
		<Property Id="SSIS32_2017_PATH_2" Secure="yes">
			<RegistrySearch Type="directory" Id="SSIS32_2017_PATH_p2" Root="HKLM" Key="SOFTWARE\Microsoft\Microsoft SQL Server\140\DTS\Setup" Name="SQLPath" Win64="no"/>
		</Property>
		<Property Id="SSIS32_2017_PATH" Secure="yes" />
		<SetProperty Action="SSIS32_2017_PATH_a" Id="SSIS32_2017_PATH" Sequence="both" After="AppSearch" Value=""/>
		<SetProperty Action="SSIS32_2017_PATH_a1" Id="SSIS32_2017_PATH" Sequence="both" After="AppSearch" Value="[SSIS32_2017_PATH_1]">SSIS32_2017_PATH=""</SetProperty>
		<SetProperty Action="SSIS32_2017_PATH_a2" Id="SSIS32_2017_PATH" Sequence="both" After="AppSearch" Value="[SSIS32_2017_PATH_2]">SSIS32_2017_PATH=""</SetProperty>
		<SetProperty Action="SSIS32_2017_PATH_a3" Id="SSIS32_2017_PATH" Sequence="both" After="AppSearch" Value="[ProgramFilesFolder]\Microsoft SQL Server\140\DTS">SSIS32_2017_PATH=""</SetProperty>

		<!-- At this point we have discovered the SQL Server SSIS path locations -->

		<!-- The following attempts to detect if SSIS or SSDT's is installed -->

		<Property Id="SSIS64_2025" Secure="yes">
			<RegistrySearch Type="raw" Id="SSIS64_2025_1" Root="HKLM" Key="SOFTWARE\Microsoft\Microsoft SQL Server\170\DTS\Setup" Name="Edition" Win64="yes"/>
			<RegistrySearch Type="raw" Id="SSIS64_2025_2" Root="HKLM" Key="SOFTWARE\Microsoft\Microsoft SQL Server\170\SSIS\Setup\DTSPath" Win64="yes"/>
			<!--<RegistrySearch Type="raw" Id="SSIS64_2025_2" Root="HKCR" Key="IntegrationServices.Package.170" Win64="yes"/> -->
		</Property>

		<Property Id="SSIS32_2025" Secure="yes">
			<RegistrySearch Type="raw" Id="SSIS32_2025_1" Root="HKLM" Key="SOFTWARE\Microsoft\Microsoft SQL Server\170\DTS\Setup" Name="Edition" Win64="no"/>
			<RegistrySearch Type="raw" Id="SSIS32_2025_2" Root="HKCR" Key="IntegrationServices.Package.170" Win64="no"/>
			<RegistrySearch Type="raw" Id="SSIS32_2025_3" Root="HKLM" Key="SOFTWARE\Microsoft\Microsoft SQL Server\170\SSIS\Setup\DTSPath" Win64="no"/>
		</Property>

		<Property Id="SSIS64_2022" Secure="yes">
			<RegistrySearch Type="raw" Id="SSIS64_2022_1" Root="HKLM" Key="SOFTWARE\Microsoft\Microsoft SQL Server\160\DTS\Setup" Name="Edition" Win64="yes"/>
			<RegistrySearch Type="raw" Id="SSIS64_2022_2" Root="HKLM" Key="SOFTWARE\Microsoft\Microsoft SQL Server\160\SSIS\Setup\DTSPath" Win64="yes"/>
			<!--<RegistrySearch Type="raw" Id="SSIS64_2022_2" Root="HKCR" Key="IntegrationServices.Package.160" Win64="yes"/> -->
		</Property>

		<Property Id="SSIS32_2022" Secure="yes">
			<RegistrySearch Type="raw" Id="SSIS32_2022_1" Root="HKLM" Key="SOFTWARE\Microsoft\Microsoft SQL Server\160\DTS\Setup" Name="Edition" Win64="no"/>
			<RegistrySearch Type="raw" Id="SSIS32_2022_2" Root="HKCR" Key="IntegrationServices.Package.160" Win64="no"/>
			<RegistrySearch Type="raw" Id="SSIS32_2022_3" Root="HKLM" Key="SOFTWARE\Microsoft\Microsoft SQL Server\160\SSIS\Setup\DTSPath" Win64="no"/>
		</Property>

